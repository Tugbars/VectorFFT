; Auto-emitted headers (section 38h): regenerated and promoted into the
; source tree by `dune build` whenever the emitters or spike_wisdom.txt
; change. registry.h is HAND-WRITTEN (ISA dispatcher) and has no rule.
(rule
 (targets plan_executors.h)
 (deps %{exe:../bin/emit_executor_h.exe} spike_wisdom.txt)
 (mode promote)
 (action
  (with-stdout-to plan_executors.h
   (run %{exe:../bin/emit_executor_h.exe} --wisdom %{dep:spike_wisdom.txt}))))
(rule
 (targets registry_avx2.h)
 (deps %{exe:../bin/emit_registry_h.exe})
 (mode promote)
 (action
  (with-stdout-to registry_avx2.h
   (run %{exe:../bin/emit_registry_h.exe} --isa avx2))))
(rule
 (targets registry_avx512.h)
 (deps %{exe:../bin/emit_registry_h.exe})
 (mode promote)
 (action
  (with-stdout-to registry_avx512.h
   (run %{exe:../bin/emit_registry_h.exe} --isa avx512))))
; rfft codelet registry (section 63): auto-emitted from Coverage.files
; "rfft-<isa>" — the single source of truth — so adding an rfft codelet
; auto-populates an ABI-typed slot. Mirrors the c2c registry rules above.
(rule
 (targets rfft_registry_avx2.h)
 (deps %{exe:../bin/emit_rfft_registry.exe})
 (mode promote)
 (action
  (with-stdout-to rfft_registry_avx2.h
   (run %{exe:../bin/emit_rfft_registry.exe} --isa avx2))))
(rule
 (targets rfft_registry_avx512.h)
 (deps %{exe:../bin/emit_rfft_registry.exe})
 (mode promote)
 (action
  (with-stdout-to rfft_registry_avx512.h
   (run %{exe:../bin/emit_rfft_registry.exe} --isa avx512))))
; OOP codelet registry (section 64): auto-emitted from Coverage.files
; "oop-<isa>". Two ABIs (11-arg regular, 7-arg spec) get distinct typed
; slots; flat and log3 t1p are BOTH reachable (selection is a planner job).
(rule
 (targets oop_registry_avx2.h)
 (deps %{exe:../bin/emit_oop_registry.exe})
 (mode promote)
 (action
  (with-stdout-to oop_registry_avx2.h
   (run %{exe:../bin/emit_oop_registry.exe} --isa avx2))))
(rule

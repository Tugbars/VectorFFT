# Auto detect text files and perform LF normalization
* text=auto

# Treat notebooks as binary (skip diff/merge noise)
*.ipynb linguist-generated
*.ipynb -diff

# Auto-generated headers — collapse in GitHub diff views, do not hand-edit.
# src/core/generated/* linguist-generated

# DAG-compiler output: ~350k lines of machine-generated codelets.
# Excluded from GitHub's language-percentage bar; files stay in the repo and
# remain fully browsable/downloadable. The decision-making code (core/ + *.ml)
# is intentionally NOT excluded so it still counts.
src/dag-fft-compiler/codelets/**            linguist-generated

# DAG-compiler generated headers (registries, plan_executors, etc.) — also
# machine output, not decision-making code. Excluded from the language bar.
src/dag-fft-compiler/generator/generated/** linguist-generated

# Benchmarks, dev scratch, and tests — kept in the repo for users, but not
# part of the shipped library, so excluded from the language bar.
build_tuned/benches/** linguist-vendored
build_tuned/dev/**     linguist-vendored
build_tuned/test/**    linguist-vendored

# Cost-model code (and its generated tables) — excluded from the language bar.
src/dag-fft-compiler/generator/cost_model/** linguist-vendored

# JIT runtime-codegen OUTPUT (machine-generated .c/.dll codelets emitted at
# runtime). Visible/browsable in the repo, but excluded from the language bar —
# same rationale as the static codelets. Hand-written JIT tooling (emit_*.py,
# prelude/runtime headers) is NOT excluded, so it still counts.
src/dag-fft-compiler/jit/generated/** linguist-generated

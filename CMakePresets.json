{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 16, "patch": 0 },

    "configurePresets": [
        {
            "name": "icx-ninja",
            "displayName": "ICX (Intel oneAPI) — Ninja",
            "description": "Intel ICX with Ninja generator. Requires icx on PATH (source oneAPI setvars).",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-icx",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "icx"
            }
        },
        {
            "name": "gcc-mingw",
            "displayName": "GCC (MinGW-w64) — Windows",
            "description": "MinGW-w64 GCC with MinGW Makefiles. Requires gcc and mingw32-make on PATH.",
            "generator": "MinGW Makefiles",
            "binaryDir": "${sourceDir}/build-gcc",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "gcc-linux",
            "displayName": "GCC — Linux",
            "description": "System GCC with Unix Makefiles. Requires gcc and make (or ninja) on PATH.",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        }
    ],

    "buildPresets": [
        {
            "name": "icx-ninja",
            "configurePreset": "icx-ninja"
        },
        {
            "name": "gcc-mingw",
            "configurePreset": "gcc-mingw"
        },
        {
            "name": "gcc-linux",
            "configurePreset": "gcc-linux"
        }
    ]
}
